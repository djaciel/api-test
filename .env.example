# Brale API credentials (testnet)
# Get these from the Brale dashboard: https://app.brale.xyz → Settings → API Credentials → Testnet
BRALE_CLIENT_ID=your_client_id_here
BRALE_CLIENT_SECRET=your_client_secret_here

# Optional: specify account ID (otherwise uses first account from GET /accounts)
# BRALE_ACCOUNT_ID=your_account_id_here
